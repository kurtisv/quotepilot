generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "quotepilot"]
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  emailVerified    DateTime?
  image            String?
  accounts         Account[]
  sessions         Session[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@schema("quotepilot")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@schema("quotepilot")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("quotepilot")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@schema("quotepilot")
}

// QuotePilot models

model Client {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  companyName String?
  phone       String?
  address     String?
  sourceApp   String?
  sourceEventId String?
  flowId      String?
  quotes      Quote[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([flowId])
  @@schema("quotepilot")
}

model Quote {
  id            String      @id @default(cuid())
  quoteNumber   String      @unique
  title         String
  description   String?
  status        QuoteStatus @default(DRAFT)
  clientId      String
  client        Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items         QuoteItem[]
  subtotalCents Int         @default(0)
  taxCents      Int         @default(0)
  totalCents    Int         @default(0)
  taxRateBps    Int         @default(1498) // basis points: 14.975% = 1497.5 ~ 1498
  publicToken   String      @unique
  validUntil    DateTime?
  sentAt        DateTime?
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  flowId        String?
  sourceApp     String?
  sourceEventId String?
  consultantName String?
  contextJson   Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([flowId])
  @@schema("quotepilot")
}

model QuoteItem {
  id             String   @id @default(cuid())
  quoteId        String
  quote          Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  quantity       Int      @default(1)
  unitPriceCents Int
  totalCents     Int
  position       Int      @default(0)

  @@index([quoteId])
  @@schema("quotepilot")
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED

  @@schema("quotepilot")
}

enum Role {
  ADMIN
  OWNER
  MEMBER
  CUSTOMER

  @@schema("quotepilot")
}

model EcosystemEvent {
  id            String   @id @default(cuid())
  flowId        String
  sourceApp     String
  targetApp     String?
  eventType     String
  entityType    String
  entityId      String?
  customerName  String?
  customerEmail String?
  title         String
  description   String?
  payload       Json?
  status        String   @default("NEW")
  createdAt     DateTime @default(now())
  readAt        DateTime?

  @@index([flowId])
  @@index([sourceApp])
  @@index([targetApp])
  @@index([eventType])
  @@index([createdAt])
  @@schema("public")
}

model EcosystemNotification {
  id          String   @id @default(cuid())
  appKey      String
  eventId     String
  flowId      String?
  title       String
  message     String
  priority    String   @default("NORMAL")
  isRead      Boolean  @default(false)
  actionLabel String?
  actionUrl   String?
  createdAt   DateTime @default(now())

  @@index([appKey])
  @@index([eventId])
  @@index([flowId])
  @@index([isRead])
  @@index([createdAt])
  @@schema("public")
}

model EcosystemEntityLink {
  id             String   @id @default(cuid())
  flowId         String
  fromApp        String
  fromEntityType String
  fromEntityId   String
  toApp          String
  toEntityType   String
  toEntityId     String?
  createdAt      DateTime @default(now())

  @@index([flowId])
  @@index([fromApp])
  @@index([toApp])
  @@schema("public")
}

