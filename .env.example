# QuotePilot — example environment variables
# Copy to .env.local and fill in your values. Never commit .env.local.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3001
APP_NAME=QuotePilot

# Database (Supabase Postgres or any Postgres)
DATABASE_URL=postgresql://user:password@host:5432/quotepilot?sslmode=require

# Auth.js v5
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3001

# Demo login (disabled in production by default)
AUTH_ENABLE_DEMO_LOGIN=true
AUTH_DEMO_EMAIL=admin@quotepilot.dev
AUTH_DEMO_PASSWORD=password123

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=QuotePilot <noreply@yourdomain.com>

# Keep-alive cron protection
PING_SECRET=change-me-random-string
